{
  "name": "ecoroute-monorepo",
  "version": "1.0.0",
  "description": "AI-powered sustainable logistics platform",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm start"
  },
  "keywords": [
    "logistics",
    "sustainability",
    "routing"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "firebase": "^12.13.0"
  }
}
